<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
{% if isRoot -%}
  <script>
  (function(){try{
    if(location.search.indexOf('nr')!==-1)return;
    var S=['en','ko','ja','zh-CN','zh-TW','de','es','fr','pt-BR','ru','tr'];
    function match(l){
      if(!l)return null;
      if(S.indexOf(l)!==-1)return l;
      if(/^zh/i.test(l))return /Hant|TW|HK|MO/i.test(l)?'zh-TW':'zh-CN';
      if(/^pt/i.test(l))return 'pt-BR';
      var b=l.split('-')[0];
      return S.indexOf(b)!==-1?b:null;
    }
    var target=null;
    try{target=localStorage.getItem('pmx-locale');}catch(_){}
    if(!target){
      var langs=navigator.languages||[navigator.language||'en'];
      for(var i=0;i<langs.length;i++){var m=match(langs[i]);if(m){target=m;break;}}
    }
    if(target&&target!=='en')location.replace('./'+target+'/');
  }catch(_){}})();
  </script>
{%- else -%}
  <script>try{localStorage.setItem('pmx-locale','{{ lang }}');}catch(_){}</script>
{%- endif %}
