<body>
{{ content | safe }}
  <footer>
    <div class="foot-brand">
      <svg class="brand-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><polyline points="4 17 10 11 4 5"/><line x1="12" x2="20" y1="19" y2="19"/></svg>
      <span class="wordmark"><strong>purple</strong>mux</span>
      <span class="muted" style="font-weight:400; margin-left:0.4rem">MIT License</span>
      <span class="foot-tagline"><span class="pct">100%</span> Claude Code · <span class="pct">0%</span> keyboard</span>
    </div>
    <div class="foot-links">
      <a href="/purplemux/docs/">Docs</a>
      <a href="https://github.com/subicura/purplemux" target="_blank" rel="noopener">GitHub</a>
      <a href="https://github.com/subicura/purplemux/releases" target="_blank" rel="noopener">Releases</a>
      <a href="https://github.com/subicura/purplemux/blob/main/README.md" target="_blank" rel="noopener">README</a>
      <a href="https://github.com/subicura/purplemux/issues" target="_blank" rel="noopener">Issues</a>
    </div>
  </footer>

  <script>
    (function () {
      var sentinel = document.querySelector('.hero-eyebrow');
      var navBrand = document.querySelector('.nav-brand');
      if (sentinel && navBrand && 'IntersectionObserver' in window) {
        new IntersectionObserver(function (entries) {
          navBrand.classList.toggle('is-hidden', entries[0].isIntersecting);
        }, { rootMargin: '-52px 0px 0px 0px', threshold: 0 }).observe(sentinel);
      } else if (navBrand) {
        navBrand.classList.remove('is-hidden');
      }

      var showcase = document.querySelector('.stats-showcase');
      if (showcase && 'IntersectionObserver' in window) {
        new IntersectionObserver(function (entries, obs) {
          entries.forEach(function (e) {
            if (e.isIntersecting) {
              showcase.classList.add('is-visible');
              obs.unobserve(showcase);
            }
          });
        }, { rootMargin: '0px 0px -15% 0px', threshold: 0.2 }).observe(showcase);
      } else if (showcase) {
        showcase.classList.add('is-visible');
      }

      var previewMobile = document.querySelector('.preview-mobile');
      if (previewMobile && 'IntersectionObserver' in window) {
        new IntersectionObserver(function (entries, obs) {
          entries.forEach(function (e) {
            if (e.isIntersecting) {
              obs.unobserve(previewMobile);
              var delay = window.matchMedia('(max-width: 767px)').matches ? 0 : 500;
              setTimeout(function () {
                previewMobile.classList.add('is-visible');
              }, delay);
            }
          });
        }, { rootMargin: '0px 0px -10% 0px', threshold: 0.1 }).observe(previewMobile);
      } else if (previewMobile) {
        previewMobile.classList.add('is-visible');
      }


      var langLinks = document.querySelectorAll('.nav-lang .lang-opt');
      for (var i = 0; i < langLinks.length; i++) {
        langLinks[i].addEventListener('click', function () {
          var l = this.getAttribute('lang');
          if (l) { try { localStorage.setItem('pmx-locale', l); } catch (_) {} }
        });
      }
    })();
  </script>

  <script src="https://cdn.jsdelivr.net/npm/swiper@12/swiper-bundle.min.js"></script>
  <script>
    (function () {
      if (!window.Swiper) return;
      new Swiper('.preview-desktop .swiper', {
        effect: 'fade',
        fadeEffect: { crossFade: true },
        loop: true,
        allowTouchMove: false,
        observer: true,
        observeParents: true,
        autoplay: {
          delay: 6000,
          disableOnInteraction: false,
          pauseOnMouseEnter: true,
        },
        pagination: {
          el: '.preview-desktop .swiper-pagination',
          clickable: true,
        },
      });
      new Swiper('.preview-mobile .swiper', {
        effect: 'fade',
        fadeEffect: { crossFade: true },
        loop: true,
        simulateTouch: false,
        observer: true,
        observeParents: true,
        autoplay: {
          delay: 3000,
          disableOnInteraction: false,
        },
      });
    })();
  </script>

  <script src="{{ assetPrefix }}download.js?v={{ site.assetVersion.downloadJs }}" defer></script>

</body>
</html>
