{%- set loc = locale or 'en' %}
{%- set t = i18n[loc] %}
{%- set docsBasePath = '/ko/docs/' if loc == 'ko' else '/docs/' %}
{%- set docsUrlPrefix = '/purplemux' + docsBasePath %}
{%- set landingUrl = '/purplemux/ko/' if loc == 'ko' else '/purplemux/' %}
<!DOCTYPE html>
<html lang="{{ loc }}">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }} — purplemux docs</title>
  <meta name="description" content="{{ description }}" />
  <meta property="og:title" content="{{ title }} — purplemux docs" />
  <meta property="og:description" content="{{ description }}" />
  <meta property="og:type" content="article" />
  <meta property="og:url" content="{{ site.baseUrl }}{{ page.url }}" />
  <meta property="og:image" content="{{ site.baseUrl }}/images/og-image.png" />
  <link rel="canonical" href="{{ site.baseUrl }}{{ page.url }}" />
{%- if loc == 'ko' %}
  <link rel="alternate" hreflang="en" href="{{ site.baseUrl }}{{ page.url | swapDocsLocale | replace('/purplemux', '') }}" />
  <link rel="alternate" hreflang="ko" href="{{ site.baseUrl }}{{ page.url }}" />
{%- else %}
  <link rel="alternate" hreflang="en" href="{{ site.baseUrl }}{{ page.url }}" />
  <link rel="alternate" hreflang="ko" href="{{ site.baseUrl }}{{ page.url | swapDocsLocale | replace('/purplemux', '') }}" />
{%- endif %}
  <link rel="icon" href="/purplemux/images/favicon.ico" sizes="any" />
  <link rel="icon" type="image/png" sizes="32x32" href="/purplemux/images/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/purplemux/images/favicon-16x16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/purplemux/images/apple-touch-icon.png" />
  <meta name="theme-color" content="#131313" />
  <link rel="preconnect" href="https://cdn.jsdelivr.net" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable.min.css" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,600..800&display=swap" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&display=swap" />
  <link rel="stylesheet" href="/purplemux/style.css?v={{ site.assetVersion.css }}" />
  <link rel="stylesheet" href="/purplemux/style-docs.css?v=5" />
</head>
<body class="doc-body">
  <nav class="doc-nav">
    <a href="{{ landingUrl }}" class="doc-nav-brand">
      <svg class="brand-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><polyline points="4 17 10 11 4 5"/><line x1="12" x2="20" y1="19" y2="19"/></svg>
      <span class="wordmark"><strong>purple</strong>mux</span>
      <span class="doc-nav-divider">/</span>
      <span class="doc-nav-section">{{ t.docsBrand }}</span>
    </a>
    <div class="doc-nav-spacer"></div>
    <button type="button" class="doc-search" data-doc-search aria-label="{{ t.searchLabel }}">
      <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
      <span>{{ t.searchLabel }}</span>
      <kbd>⌘K</kbd>
    </button>
    <details class="doc-nav-lang">
      <summary aria-label="{{ t.switcherAria }}">
        <span>{{ t.langLabel }}</span>
        <svg width="10" height="10" viewBox="0 0 10 10" aria-hidden="true"><path d="M2 4l3 3 3-3" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </summary>
      <div class="doc-nav-lang-menu" role="menu">
{%- if loc == 'ko' %}
        <a href="{{ page.url | swapDocsLocale }}" lang="en">English</a>
        <a href="/purplemux{{ page.url }}" lang="ko" class="is-active">한국어</a>
{%- else %}
        <a href="/purplemux{{ page.url }}" lang="en" class="is-active">English</a>
        <a href="{{ page.url | swapDocsLocale }}" lang="ko">한국어</a>
{%- endif %}
      </div>
    </details>
    <a href="https://github.com/subicura/purplemux" class="doc-nav-github" target="_blank" rel="noopener" aria-label="GitHub">
      <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56 0-.28-.01-1.02-.02-2-3.2.69-3.88-1.54-3.88-1.54-.52-1.33-1.28-1.69-1.28-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.36.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.18-3.09-.12-.29-.51-1.46.11-3.04 0 0 .97-.31 3.18 1.18a11.1 11.1 0 0 1 5.79 0c2.2-1.49 3.17-1.18 3.17-1.18.62 1.58.23 2.75.11 3.04.74.8 1.18 1.83 1.18 3.09 0 4.42-2.69 5.4-5.26 5.68.41.35.78 1.05.78 2.12 0 1.53-.01 2.77-.01 3.15 0 .31.21.67.8.56A11.5 11.5 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z"/></svg>
    </a>
  </nav>

  {%- set currentGroup = docsNav | findDocsGroup(page.fileSlug, loc) %}
  <div class="doc-mobile-header">
    <button type="button" class="doc-menu-btn" data-sidebar-open aria-label="Menu" aria-controls="doc-sidebar" aria-expanded="false">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
    <nav class="doc-breadcrumb" aria-label="Breadcrumb">
      {%- if currentGroup %}
      <span class="doc-breadcrumb-group">{{ currentGroup }}</span>
      <span class="doc-breadcrumb-sep">›</span>
      {%- endif %}
      <span class="doc-breadcrumb-current">{{ title }}</span>
    </nav>
  </div>

  <div class="doc-sidebar-backdrop" data-sidebar-backdrop hidden></div>

  <div class="doc-shell">
    <aside class="doc-sidebar" id="doc-sidebar">
      <button type="button" class="doc-sidebar-close" data-sidebar-close aria-label="{{ t.close }}">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 6l12 12M6 18L18 6"/></svg>
      </button>
      <nav class="doc-sidebar-inner" aria-label="Documentation">
{%- for group in docsNav %}
        <div class="doc-group">
          <div class="doc-group-label">{{ group.group[loc] }}</div>
{%- for item in group.items %}
          <a href="{{ docsUrlPrefix }}{{ item.slug }}/" class="doc-link{% if page.url == docsBasePath + item.slug + '/' %} is-active{% endif %}">{{ item.label[loc] }}</a>
{%- endfor %}
        </div>
{%- endfor %}
      </nav>
    </aside>

    <main class="doc-main">
      <article class="doc-article">
        <header class="doc-header">
          <div class="doc-eyebrow">{{ eyebrow or t.docsBrand }}</div>
          <h1 class="doc-title">{{ title }}</h1>
          {%- if description %}
          <p class="doc-subtitle">{{ description }}</p>
          {%- endif %}
        </header>

        <div class="doc-content" data-doc-content>
          {{ content | safe }}
        </div>

        {%- set nb = docsFlat | docsNeighbors(page.fileSlug) %}
        {%- if nb.prev or nb.next %}
        <nav class="doc-pagination" aria-label="{{ t.pagination }}">
          {%- if nb.prev %}
          <a href="{{ docsUrlPrefix }}{{ nb.prev.slug }}/" class="doc-pag-link doc-pag-prev">
            <span class="doc-pag-dir">{{ t.previous }}</span>
            <span class="doc-pag-title">{{ nb.prev.label[loc] }}</span>
          </a>
          {%- else %}
          <span></span>
          {%- endif %}
          {%- if nb.next %}
          <a href="{{ docsUrlPrefix }}{{ nb.next.slug }}/" class="doc-pag-link doc-pag-next">
            <span class="doc-pag-dir">{{ t.next }}</span>
            <span class="doc-pag-title">{{ nb.next.label[loc] }}</span>
          </a>
          {%- endif %}
        </nav>
        {%- endif %}
      </article>

      <aside class="doc-toc" aria-label="{{ t.onThisPage }}">
        <div class="doc-toc-label">{{ t.onThisPage }}</div>
        <nav class="doc-toc-list" data-doc-toc></nav>
      </aside>
    </main>
  </div>

  <div class="doc-search-overlay" data-search-overlay hidden>
    <div class="doc-search-backdrop" data-search-close></div>
    <div class="doc-search-modal" role="dialog" aria-modal="true" aria-labelledby="doc-search-label">
      <div class="doc-search-field">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
        <input type="search" class="doc-search-input" data-search-input placeholder="{{ t.searchPlaceholder }}" aria-label="{{ t.searchLabel }}" autocomplete="off" spellcheck="false" data-locale="{{ loc }}" />
        <button type="button" class="doc-search-esc" data-search-close aria-label="{{ t.close }}">Esc</button>
      </div>
      <div class="doc-search-results" data-search-results role="listbox" aria-label="Search results"></div>
      <div class="doc-search-footer">
        <span><kbd>↑</kbd><kbd>↓</kbd> {{ t.navigate }}</span>
        <span><kbd>↵</kbd> {{ t.open }}</span>
        <span><kbd>Esc</kbd> {{ t.close }}</span>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/fuse.js@7.0.0/dist/fuse.min.js" defer></script>
  <script src="/purplemux/docs.js?v=5" defer></script>
</body>
</html>
