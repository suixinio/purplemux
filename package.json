{
  "name": "purplemux",
  "version": "0.2.6",
  "description": "Manage multiple Claude Code sessions from your browser",
  "license": "MIT",
  "author": "subicura",
  "repository": {
    "type": "git",
    "url": "https://github.com/subicura/purplemux.git"
  },
  "homepage": "https://github.com/subicura/purplemux",
  "bugs": {
    "url": "https://github.com/subicura/purplemux/issues"
  },
  "keywords": [
    "claude",
    "terminal",
    "multiplexer",
    "tmux",
    "claude-code"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.32.1",
  "main": "dist-electron/main.js",
  "bin": {
    "purplemux": "./bin/purplemux.js",
    "pmux": "./bin/purplemux.js"
  },
  "files": [
    "bin/",
    "dist/",
    ".next/standalone/",
    "src/config/tmux.conf"
  ],
  "scripts": {
    "dev": "tsx watch server.ts",
    "build": "next build && node scripts/post-build.js && tsup",
    "build:landing": "eleventy",
    "dev:landing": "eleventy --serve",
    "build:server": "tsup",
    "build:electron:main": "tsup --config electron/tsup.config.ts",
    "build:electron": "next build && node scripts/post-build.js --electron && tsup && pnpm build:electron:main",
    "dev:electron": "ELECTRON_DEV_URL=http://localhost:8022 electron .",
    "pack:electron": "pnpm build:electron && electron-builder --mac",
    "pack:electron:dev": "pnpm build:electron && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac -c.mac.identity=null -c.mac.notarize=false",
    "start": "NODE_ENV=production tsx server.ts",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "ralph": "node ralph-loop.js",
    "prepublishOnly": "rm -rf .next dist dist-electron && pnpm build",
    "postinstall": "chmod +x node_modules/.pnpm/node-pty@*/node_modules/node-pty/prebuilds/*/spawn-helper 2>/dev/null; exit 0"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@git-diff-view/core": "^0.1.3",
    "@git-diff-view/file": "^0.1.3",
    "@git-diff-view/react": "^0.1.3",
    "@tailwindcss/typography": "^0.5.19",
    "@xterm/addon-clipboard": "^0.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dayjs": "^1.11.20",
    "diff": "^9.0.0",
    "electron-updater": "^6.8.3",
    "jose": "^6.2.2",
    "lucide-react": "^1.7.0",
    "motion": "^12.38.0",
    "nanoid": "^5.1.7",
    "next": "16.2.4",
    "next-intl": "^4.9.1",
    "next-themes": "^0.4.6",
    "node-pty": "1.2.0-beta.12",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^4.0.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hotkeys-hook": "^5.2.4",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.10.0",
    "recharts": "^3.8.0",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "update-notifier": "^7.3.1",
    "use-stick-to-bottom": "^1.1.3",
    "vaul": "^1.1.2",
    "web-push": "^3.6.7",
    "ws": "^8.20.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^24.12.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.18.1",
    "chalk": "^5.6.2",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "shadcn": "^4.1.2",
    "tailwindcss": "^4",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "node-pty"
    ],
    "overrides": {
      "hono": ">=4.12.14",
      "@hono/node-server": ">=1.19.13",
      "lodash": ">=4.18.0",
      "@xmldom/xmldom": "^0.8.13",
      "picomatch@>=2.0.0 <3.0.0": ">=2.3.2",
      "picomatch@>=4.0.0 <5.0.0": ">=4.0.4"
    }
  }
}
