{
  "name": "purplemux",
  "version": "0.1.0",
  "license": "MIT",
  "main": "dist-electron/main.js",
  "bin": {
    "purplemux": "./bin/purplemux.js",
    "pmux": "./bin/purplemux.js"
  },
  "files": [
    "bin/",
    "dist/",
    ".next/standalone/",
    "public/",
    "src/config/tmux.conf"
  ],
  "scripts": {
    "dev": "tsx watch server.ts",
    "build": "next build && node scripts/post-build.js && tsup",
    "build:server": "tsup",
    "build:electron:main": "tsup --config electron/tsup.config.ts",
    "build:electron": "pnpm build && pnpm build:electron:main",
    "dev:electron": "ELECTRON_DEV_URL=http://localhost:8022 electron .",
    "pack:electron": "pnpm build:electron && electron-builder --mac",
    "pack:electron:dev": "pnpm build:electron && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac -c.mac.identity=null -c.mac.notarize=false",
    "start": "NODE_ENV=production tsx server.ts",
    "lint": "eslint",
    "ralph": "node ralph-loop.js",
    "prepublishOnly": "rm -rf .next dist && pnpm build",
    "postinstall": "chmod +x node_modules/.pnpm/node-pty@*/node_modules/node-pty/prebuilds/darwin-*/spawn-helper 2>/dev/null; exit 0"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-virtual": "^3.13.23",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dayjs": "^1.11.20",
    "lucide-react": "^0.577.0",
    "nanoid": "^5.1.7",
    "next": "16.2.0",
    "next-auth": "^4.24.13",
    "next-themes": "^0.4.6",
    "node-pty": "1.2.0-beta.12",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hotkeys-hook": "^5.2.4",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.7.3",
    "recharts": "^2.15.4",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.1.0",
    "sonner": "^2.0.7",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "use-stick-to-bottom": "^1.1.3",
    "vaul": "^1.1.2",
    "ws": "^8.19.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "chalk": "^5.6.2",
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "tailwindcss": "^4",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "node-pty"
    ]
  }
}
